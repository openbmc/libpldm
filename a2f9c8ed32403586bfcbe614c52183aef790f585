        "id": 1000009
      },
      "writtenOn": "2026-03-17T00:01:10Z",
      "side": 1,
      "message": "Here\u0027s a sketch of my thoughts, as a patch on top:\n\nhttps://gerrit.openbmc.org/c/openbmc/libpldm/+/88328/\n\nI think it simplifies things a bit.",
      "parentUuid": "205ea3a7_4c40540a",
      "revId": "a2f9c8ed32403586bfcbe614c52183aef790f585",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
