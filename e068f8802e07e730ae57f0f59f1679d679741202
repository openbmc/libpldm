      "side": 1,
      "message": "This seems inconsistent. We allow searching with MCTP_NET_ANY (which is 0), but it is blocked here.",
      "revId": "e068f8802e07e730ae57f0f59f1679d679741202",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
    {
      "unresolved": true,
      "key": {
        "uuid": "fd8c382b_a603f6b9",
        "filename": "src/transport/af-mctp.c",
        "patchSetId": 30
      },
      "lineNbr": 81,
