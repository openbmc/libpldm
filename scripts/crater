#!/usr/bin/make -f

# Named after Rust's 'crater' subproject. The naming makes a lot more sense
# there, but we're adopting it as the spirit is similar.
#
# https://github.com/rust-lang/crater

LIBPLDM_DIR := $(shell pwd)
LIBPLDM_REF := HEAD

.PHONY: all
all: make-pldm make-phosphor-bmc-code-mgmt

define LIBPLDM_CRATER_REPO

$($(1)_DIR)/.git:
	git clone --depth 1 $(2) $$($(1)_DIR)

$($(1)_DIR)/build: $$($(1)_DIR)/.git
	meson setup --force-fallback-for=libpldm $$($(1)_DIR)/build
	git -C $$($(1)_DIR)/subprojects/libpldm pull --ff-only $$(LIBPLDM_DIR) $$(LIBPLDM_REF)

$($(1)_DIR)/build/$(3): $$($(1)_DIR)/build
	meson compile -C $$($(1)_DIR)/build
	meson test -C $$($(1)_DIR)/build

.PHONY: meson-$(4)
meson-$(4): $$($(1)_DIR)/build/$(3)

.PHONY: make-$(4)
make-$(4): $(1)_DIR := $$(shell mktemp --tmpdir --directory)
make-$(4):
	$$(MAKE) -C $$($(1)_DIR) \
		-f $$(abspath $$(lastword $$(MAKEFILE_LIST))) \
		meson-$(4) \
		LIBPLDM_DIR=$$(LIBPLDM_DIR) \
		LIBPLDM_REF=$$(LIBPLDM_REF) \
		$(1)_DIR=$$($(1)_DIR)
	$$(RM) -r $$($(1)_DIR)

endef

$(eval $(call LIBPLDM_CRATER_REPO,PLDM,https://github.com/openbmc/pldm.git,pldmd,pldm))

$(eval $(call LIBPLDM_CRATER_REPO,PHOSPHOR_BMC_CODE_MGMT,https://github.com/openbmc/phosphor-bmc-code-mgmt.git,bios/phosphor-bios-software-update,phosphor-bmc-code-mgmt))
