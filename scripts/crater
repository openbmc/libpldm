#!/usr/bin/make -f

# Named after Rust's 'crater' subproject. The naming makes a lot more sense
# there, but we're adopting it as the spirit is similar.
#
# https://github.com/rust-lang/crater

LIBPLDM_DIR := $(shell pwd)
LIBPLDM_REF := HEAD

.PHONY: all
all: make-pldm

$(PLDM_DIR)/.git:
	git clone --depth 1 https://github.com/openbmc/pldm.git $(PLDM_DIR)

$(PLDM_DIR)/build: $(PLDM_DIR)/.git
	meson setup --force-fallback-for=libpldm $(PLDM_DIR)/build
	git -C subprojects/libpldm pull --ff-only $(LIBPLDM_DIR) $(LIBPLDM_REF)

$(PLDM_DIR)/build/pldmd: $(PLDM_DIR)/build
	meson compile -C $(PLDM_DIR)/build
	meson test -C $(PLDM_DIR)/build

.PHONY: meson-pldm
meson-pldm: $(PLDM_DIR)/build/pldmd

.PHONY: make-pldm
make-pldm: PLDM_DIR := $(shell mktemp --tmpdir --directory)
make-pldm:
	$(MAKE) -C $(PLDM_DIR) \
			-f $(abspath $(lastword $(MAKEFILE_LIST))) \
			meson-pldm \
			LIBPLDM_REF=$(LIBPLDM_REF) \
			LIBPLDM_DIR=$(LIBPLDM_DIR) \
			PLDM_DIR=$(PLDM_DIR)
	$(RM) -r $(PLDM_DIR)
