      "writtenOn": "2026-04-29T05:15:21Z",
      "side": 1,
      "message": "For responses whose only content is a completion code I still require `encode_*()` and `decode_*()` APIs, but I don\u0027t require that you pass a struct for them. You can just pass the completion code by value or pointer as necessary.",
      "range": {
        "startLine": 1413,
        "startChar": 0,
        "endLine": 1419,
        "endChar": 2
      },
      "revId": "2d20771789f6e42d7376586ae672ce557add70ea",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
